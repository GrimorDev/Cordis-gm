dangerously-allow-all-builds=true
public-hoist-pattern[]=source-map-js
public-hoist-pattern[]=*source-map*

# Windows CI fix: avoid symlink-based bin linking (EPERM with native modules like msgpackr-extract)
# node-linker=hoisted makes pnpm use flat node_modules like npm — no realpath/symlink issues
node-linker=hoisted
