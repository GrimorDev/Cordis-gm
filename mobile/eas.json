{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://cordyn.pl/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://cordyn.pl"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://cordyn.pl/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://cordyn.pl"
      }
    }
  }
}
