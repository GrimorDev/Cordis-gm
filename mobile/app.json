{
  "expo": {
    "name": "Cordyn",
    "slug": "cordyn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cordyn",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#09090b",
    "splash": {
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cordis.cordyn",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Cordyn potrzebuje dostępu do mikrofonu dla kanałów głosowych.",
        "NSCameraUsageDescription": "Cordyn potrzebuje dostępu do kamery dla rozmów wideo.",
        "NSPhotoLibraryUsageDescription": "Cordyn potrzebuje dostępu do zdjęć, aby wysyłać obrazy."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090b"
      },
      "package": "com.cordis.cordyn",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/icon.png",
      "themeColor": "#6366f1",
      "backgroundColor": "#09090b"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "baseUrl": "/app"
    }
  }
}
