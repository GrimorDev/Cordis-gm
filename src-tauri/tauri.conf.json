{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cordyn",
  "version": "0.2.1003",
  "identifier": "com.cordis.cordyn",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cordyn",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": true,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "backgroundColor": "#09090b",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFNkE0NjA2NzE3OENGNkQKUldSdHozaHhCa1pxWHJCU0tKUmF2YUhuNkVoMm1ZbCtjMUx3MlI5WGM0RFZYeVlqSkdPVVViUkMK",
      "endpoints": [
        "https://github.com/GrimorDev/Cordis-gm/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "shell": {
      "open": true
    }
  }
}
