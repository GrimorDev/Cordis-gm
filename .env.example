# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cordis
POSTGRES_USER=cordis
POSTGRES_PASSWORD=change_this_strong_password

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change_this_jwt_secret_minimum_32_chars_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Backend ───────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=https://yourdomain.com
UPLOAD_MAX_SIZE=52428800

# ── Cloudflare R2 Storage ──────────────────────────────────────────────
# Bez ACCESS_KEY_ID + SECRET aplikacja używa lokalnego dysku (fallback)
# Klucze: CF Dashboard → R2 → Manage R2 API Tokens → Create API Token
#   Uprawnienia: Object Read & Write; Apply to bucket: cordyn
R2_ENDPOINT=https://f33e20b4cd126676f4659f7838db83cd.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<wygeneruj_w_CF_R2_API_Tokens>
R2_SECRET_ACCESS_KEY=<wygeneruj_w_CF_R2_API_Tokens>
R2_BUCKET=cordyn
#
# Publiczny URL bucketu — pliki serwowane bezpośrednio przez Cloudflare CDN
# Gdy nie ustawiony → fallback: /api/files/* (pre-signed URL przez backend)
R2_PUBLIC_URL=https://pub-3f56fb1df8af4fcbb4f843cebfe0bf42.r2.dev

# ── Storage quotas ─────────────────────────────────────────────────────
STORAGE_FREE_QUOTA=52428800       # 50 MB
STORAGE_PREMIUM_QUOTA=629145600   # 600 MB (Cordyn Power)

# ── LiveKit SFU ───────────────────────────────────────────────────────
# Generate a key pair: any random strings work, e.g.:
#   openssl rand -hex 16   → API key
#   openssl rand -hex 32   → API secret (min 32 chars)
# The same values must match in docker-compose.yml LIVEKIT_API_KEY / LIVEKIT_API_SECRET
LIVEKIT_API_KEY=changeme_livekit_api_key
LIVEKIT_API_SECRET=changeme_livekit_api_secret_minimum_32_chars

# LiveKit WebSocket URL visible to the browser.
# In production (behind nginx): wss://yourdomain.com/livekit
# Leave empty → auto-derived from window.location (works with the nginx proxy block)
VITE_LIVEKIT_URL=

# ── TURN relay (coturn) — wymagane dla niezawodnych połączeń głosowych/wideo ──
# Bez TURN-a same serwery STUN nie wystarczą: dwie osoby za symetrycznym
# NAT-em / CGNAT-em / restrykcyjną zaporą NIGDY się nie połączą bezpośrednio
# (wygląda to jak "czasem łączy, czasem nie" zależnie od sieci rozmówców).
# coturn jest już zdefiniowany w docker-compose.yml — wystarczy ustawić:
#   1) TURN_USERNAME / TURN_PASSWORD  → poświadczenia serwera coturn
#      (hasło min. 16 znaków, np. `openssl rand -hex 16`)
#   2) VITE_TURN_URL                  → PUBLICZNY adres tego serwera
#      np. turn:1.2.3.4:3478  albo  turn:turn.twoja-domena.com:3478
# Pamiętaj: porty 3478 (TCP+UDP) i 49160-49360/udp muszą być otwarte na
# zewnątrz (firewall/security group VPS-a) — to jest realny adres relay,
# inaczej niż LiveKit/backend nie da się ukryć za samym Nginxem.
# Te dwie wartości trafiają RAZEM do (a) loginu coturn ORAZ (b) build-argów
# VITE_TURN_USERNAME/VITE_TURN_CREDENTIAL we frontendzie (patrz docker-compose.yml)
# — dzięki temu przeglądarka i serwer zawsze mają zgodne poświadczenia,
# nie trzeba ich osobno duplikować.
TURN_REALM=cordis.turn
TURN_USERNAME=cordis
TURN_PASSWORD=changeme_turn_password_min_16_chars
VITE_TURN_URL=

# ── Frontend (Vite build args) ────────────────────────────────────────
VITE_API_URL=/api
VITE_SOCKET_URL=
# Public VAPID key for Web Push (must match VAPID_PUBLIC_KEY below)
VITE_VAPID_PUBLIC_KEY=BLW91bYO5prQrQtHpsE_6dJQVi3jQvGmD5MJbj8oRQ6aesobJm4GLzBTq_DyEfsFoi5yLJeGenO-27FoOe8w06I
# Tenor GIF API key — get for free at https://developers.google.com/tenor/guides/quickstart
VITE_TENOR_API_KEY=

# ── Web Push / VAPID ─────────────────────────────────────────────────
# Generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=BLW91bYO5prQrQtHpsE_6dJQVi3jQvGmD5MJbj8oRQ6aesobJm4GLzBTq_DyEfsFoi5yLJeGenO-27FoOe8w06I
VAPID_PRIVATE_KEY=vFvp3YBmW3noenXtZTAL5eODAZkZisJsR3Mz8yzK1Ic
VAPID_EMAIL=admin@cordyn.pl

# ── Spotify (developer.spotify.com — completely free, read-only) ──────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Must match exactly what you set in Spotify Dashboard > Redirect URIs
SPOTIFY_REDIRECT_URI=https://yourdomain.com/api/spotify/callback

# ── Steam (steamcommunity.com/dev/apikey — completely free) ───────────
STEAM_API_KEY=your_steam_api_key
# Must match exactly what you set in steam connect route
STEAM_REDIRECT_URI=https://yourdomain.com/api/steam/callback

# ── Twitch (dev.twitch.tv/console — completely free) ──────────────────
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
# Must match exactly what you add in Twitch Developer Console > OAuth Redirect URLs
TWITCH_REDIRECT_URI=https://yourdomain.com/api/twitch/callback

# ── YouTube (Google OAuth2) ──────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → YouTube Data API v3 → Credentials → OAuth 2.0
# IMPORTANT: In OAuth consent screen → Publishing status → click "Publish App" (users will see
# "unverified app" warning but can bypass it; full verification optional for small apps)
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=https://yourdomain.com/api/auth/youtube/callback

# ── Kick (OAuth2) ────────────────────────────────────────────────────
# Create at: https://kick.com/settings/developer → New Application
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret
KICK_REDIRECT_URI=https://yourdomain.com/api/kick/callback
